{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "1-Python: Debug AI Service (Uvicorn)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/services/ai-service/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/services/ai-service",
            "justMyCode": false
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug manage_schema_metadata.mjs",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/scripts/manage_schema_metadata.mjs"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current JS/MJS File",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${file}"
        }
    ]
}
