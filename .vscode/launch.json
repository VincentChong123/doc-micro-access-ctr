{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "1-Python: Debug AI Service (Uvicorn)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/services/ai_service/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/services/ai_service",
            "justMyCode": false
        },
        {
            "name": "2-Python: Debug Current File as Module",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/run_as_module.py",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug manage_schema_metadata.mjs",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/scripts/manage_schema_metadata.mjs"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current JS/MJS File",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${file}"
        }
    ]
}
